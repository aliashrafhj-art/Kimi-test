# Video Automation Tool - Environment Variables

# Telegram Configuration (Required for uploads)
TELEGRAM_BOT_TOKEN=8762932401:AAHoWrdYm8fhIt2e1RB-qktQhc5gFFa1ONQ
TELEGRAM_CHANNEL_ID=@anisubbd

# App Settings
DEBUG=false
PORT=8000

# Paths (Railway uses /tmp for ephemeral storage)
TEMP_DIR=/tmp/video-automation
DOWNLOAD_DIR=/tmp/video-automation/downloads
FONT_DIR=./fonts

# Video Processing
MAX_CONCURRENT_DOWNLOADS=2
VIDEO_QUALITY=720p

# Subtitle Settings
SUBTITLE_FONT=Noto Sans Bengali
SUBTITLE_FONT_SIZE=28
SUBTITLE_COLOR=#FFFFFF
SUBTITLE_OUTLINE_COLOR=#000000
SUBTITLE_OUTLINE_WIDTH=2

# Redis (for Celery - optional)
REDIS_URL=redis://localhost:6379/0
